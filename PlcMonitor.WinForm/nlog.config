<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

	<targets async="true">
		<target name="error" xsi:type="File" fileName="logs/${shortdate}.txt" archiveAboveSize="10485760"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message}"/>

		<target name="warn" xsi:type="File" fileName="logs/${shortdate}.txt" archiveAboveSize="10485760"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message}"/>

		<target name="file" xsi:type="File" fileName="logs/${shortdate}.txt" archiveAboveSize="10485760"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message}"/>

		<target name="console" xsi:type="Console" 
				layout="${longdate}|${level:uppercase=true}|${logger}|${message}"/>
	</targets>

	<rules>
		<logger name="*" minlevel="Info" writeTo="console" />
		<logger name="*" minlevel="Error" writeTo="error" />
		<logger name="*" minlevel="Warn" maxlevel="Warn" writeTo="warn" />
		<logger name="*" minlevel="Debug" writeTo="file" />
	</rules>
</nlog>