<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

	<targetsOld async="true">
		<target name="error" xsi:type="File" fileName="logs/${shortdate}.txt"
				archiveAboveSize="10485760" maxArchiveFiles="300" maxArchiveDays="30"
				archiveEvery="Day" archiveFileName="logs/nlog-${shortdate}.{#}.txt"
				autoFlush="false" keepFileOpen="true" openFileFlushTimeout="2" openFileCacheTimeout="60" bufferSize="32768"
				layout="${time} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"/>

		<target name="warn" xsi:type="File" fileName="logs/${shortdate}.txt"
				archiveAboveSize="10485760" maxArchiveFiles="300" maxArchiveDays="30"
				archiveEvery="Day" archiveFileName="logs/nlog-${shortdate}.{#}.txt"
				autoFlush="false" keepFileOpen="true" openFileFlushTimeout="2" openFileCacheTimeout="60" bufferSize="32768"
				layout="${time} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"/>

		<target name="file" xsi:type="File" fileName="logs/${shortdate}.txt"
				archiveAboveSize="10485760" maxArchiveFiles="300" maxArchiveDays="30"
				archiveEvery="Day" archiveFileName="logs/nlog-${shortdate}.{#}.txt"
				autoFlush="false" keepFileOpen="true" openFileFlushTimeout="2" openFileCacheTimeout="60" bufferSize="32768"
				layout="${time} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"/>

		<target name="console" xsi:type="Console"
				layout="${time} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"/>
	</targetsOld>

	<targets>
		<target name="errorAsync" xsi:type="AsyncWrapper" queueLimit="10000">
			<target name="error" xsi:type="File" fileName="logs/${shortdate}.txt"
					archiveAboveSize="10485760" maxArchiveFiles="300" maxArchiveDays="30"
					archiveEvery="Day" archiveFileName="logs/nlog-${shortdate}.{#}.txt"
					autoFlush="false" keepFileOpen="true" openFileFlushTimeout="2" openFileCacheTimeout="60" bufferSize="32768"
					layout="${time} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"/>

		</target>
		<target name="warnAsync" xsi:type="AsyncWrapper" queueLimit="10000">
			<target name="warn" xsi:type="File" fileName="logs/${shortdate}.txt"
					archiveAboveSize="10485760" maxArchiveFiles="300" maxArchiveDays="30"
					archiveEvery="Day" archiveFileName="logs/nlog-${shortdate}.{#}.txt"
					autoFlush="false" keepFileOpen="true" openFileFlushTimeout="2" openFileCacheTimeout="60" bufferSize="32768"
					layout="${time} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"/>

		</target>
		<target name="fileAsync" xsi:type="AsyncWrapper" queueLimit="10000">
			<target name="file" xsi:type="File" fileName="logs/${shortdate}.txt"
					archiveAboveSize="10485760" maxArchiveFiles="300" maxArchiveDays="30"
					archiveEvery="Day" archiveFileName="logs/nlog-${shortdate}.{#}.txt"
					autoFlush="false" keepFileOpen="true" openFileFlushTimeout="2" openFileCacheTimeout="60" bufferSize="32768"
					layout="${time} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"/>

		</target>
		<target name="consoleAsync" xsi:type="AsyncWrapper" queueLimit="5000">

			<target name="console" xsi:type="Console"
					layout="${time} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"/>
		</target>
	</targets>

	<rules>
		<logger name="*" minlevel="Info" writeTo="consoleAsync" />
		<logger name="*" minlevel="Error" writeTo="errorAsync" />
		<logger name="*" minlevel="Warn" maxlevel="Warn" writeTo="warnAsync" />
		<logger name="*" minlevel="Debug" writeTo="fileAsync" />
	</rules>
</nlog>