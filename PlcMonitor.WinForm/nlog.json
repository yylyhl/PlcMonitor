{
  "NLog": {
    "autoReload": true,
    "targets": {
      "errorAsync": {
        "type": "AsyncWrapper",
        "queueLimit": 10000,
        "overflowAction": "Discard",
        "batchSize": 200,
        "target": {
          "type": "File",
          "fileName": "logs/error-${shortdate}.txt",
          "archiveAboveSize": 10485760,
          "maxArchiveFiles": 300,
          "maxArchiveDays": 30,
          "archiveEvery": "Day",
          "archiveFileName": "logs/error-${shortdate}.{#}.txt",
          "autoFlush": false,
          "keepFileOpen": true,
          "openFileFlushTimeout": 2,
          "openFileCacheTimeout": 60,
          "bufferSize": 32768,
          "layout": "${longdate} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"
        }
      },
      "warnAsync": {
        "type": "AsyncWrapper",
        "queueLimit": 10000,
        "overflowAction": "Discard",
        "batchSize": 200,
        "target": {
          "type": "File",
          "fileName": "logs/warn-${shortdate}.txt",
          "archiveAboveSize": 10485760,
          "maxArchiveFiles": 300,
          "maxArchiveDays": 30,
          "archiveEvery": "Day",
          "archiveFileName": "logs/warn-${shortdate}.{#}.txt",
          "autoFlush": false,
          "keepFileOpen": true,
          "openFileFlushTimeout": 2,
          "openFileCacheTimeout": 60,
          "bufferSize": 32768,
          "layout": "${longdate} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"
        }
      },
      "fileAsync": {
        "type": "AsyncWrapper",
        "queueLimit": 10000,
        "overflowAction": "Discard",
        "batchSize": 200,
        "target": {
          "type": "File",
          "fileName": "logs/nlog-${shortdate}.txt",
          "archiveAboveSize": 10485760,
          "maxArchiveFiles": 300,
          "maxArchiveDays": 30,
          "archiveEvery": "Day",
          "archiveFileName": "logs/nlog-${shortdate}.{#}.txt",
          "autoFlush": false,
          "keepFileOpen": true,
          "openFileFlushTimeout": 2,
          "openFileCacheTimeout": 60,
          "bufferSize": 32768,
          "layout": "${longdate} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"
        }
      },
      "consoleAsync": {
        "type": "AsyncWrapper",
        "queueLimit": 10000,
        "overflowAction": "Discard",
        "batchSize": 200,
        "target": {
          "type": "Console",
          "layout": "${longdate} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"
        }
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Debug",
        "writeTo": "consoleAsync"
      },
      {
        "logger": "*",
        "minLevel": "Error",
        "writeTo": "errorAsync"
      },
      {
        "logger": "*",
        "minLevel": "Warn",
        "maxLevel": "Warn",
        "writeTo": "warnAsync"
      },
      {
        "logger": "*",
        "minLevel": "Debug",
        "writeTo": "fileAsync"
      }
    ]
  },
  "NLog2": {
    "autoReload": true,
    "targets": {
      "_async": true,
      "error": {
        "type": "File",
        "fileName": "logs/error-${shortdate}.txt",
        "archiveAboveSize": 10485760,
        "maxArchiveFiles": 300,
        "maxArchiveDays": 30,
        "archiveEvery": "Day",
        "archiveFileName": "logs/error-${shortdate}.{#}.txt",
        "autoFlush": false,
        "keepFileOpen": true,
        "openFileFlushTimeout": 2,
        "openFileCacheTimeout": 60,
        "bufferSize": 32768,
        "layout": "${longdate} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"
      },
      "warn": {
        "type": "File",
        "fileName": "logs/warn-${shortdate}.txt",
        "archiveAboveSize": 10485760,
        "maxArchiveFiles": 300,
        "maxArchiveDays": 30,
        "archiveEvery": "Day",
        "archiveFileName": "logs/warn-${shortdate}.{#}.txt",
        "autoFlush": false,
        "keepFileOpen": true,
        "openFileFlushTimeout": 2,
        "openFileCacheTimeout": 60,
        "bufferSize": 32768,
        "layout": "${longdate} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"
      },
      "file": {
        "type": "File",
        "fileName": "logs/nlog-${shortdate}.txt",
        "archiveAboveSize": 10485760,
        "maxArchiveFiles": 300,
        "maxArchiveDays": 30,
        "archiveEvery": "Day",
        "archiveFileName": "logs/nlog-${shortdate}.{#}.txt",
        "autoFlush": false,
        "keepFileOpen": true,
        "openFileFlushTimeout": 2,
        "openFileCacheTimeout": 60,
        "bufferSize": 32768,
        "layout": "${longdate} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"
      },
      "console": {
        "type": "Console",
        "layout": "${longdate} [${level:uppercase=true}] Thread:${threadid} ${logger}: ${message} ${exception:format=tostring}"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "console"
      },
      {
        "logger": "*",
        "minLevel": "Error",
        "writeTo": "error"
      },
      {
        "logger": "*",
        "minLevel": "Warn",
        "maxLevel": "Warn",
        "writeTo": "warn"
      },
      {
        "logger": "*",
        "minLevel": "Debug",
        "writeTo": "file"
      }
    ]
  }
}